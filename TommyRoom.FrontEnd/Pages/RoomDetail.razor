@page "/rooms/{RoomId:int}"
@inject HttpClient _Http

<PageTitle>@(_room?.Name ?? "Room") — TommyRoom</PageTitle>

@if (_loading)
{
    <div class="tr-detail-skeleton">
        <div class="tr-skeleton tr-skeleton--gallery"></div>
        <div class="tr-detail-layout">
            <div class="tr-detail-info">
                <div class="tr-skeleton tr-skeleton--line tr-skeleton--short" style="margin:0 0 10px;"></div>
                <div class="tr-skeleton tr-skeleton--line" style="height:32px;margin:0 0 14px;width:60%;"></div>
                <div class="tr-skeleton tr-skeleton--line" style="margin:0 0 8px;"></div>
                <div class="tr-skeleton tr-skeleton--line" style="width:80%;"></div>
            </div>
            <div class="tr-skeleton" style="height:280px;border-radius:4px;"></div>
        </div>
    </div>
}
else if (_room is null)
{
    <div class="tr-empty" style="padding:100px 20px;">
        <div class="tr-empty__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="8" x2="12" y2="12"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
        </div>
        <div class="tr-empty__title">Room not found</div>
        <div class="tr-empty__sub" style="margin-bottom:20px;">This room may no longer be available.</div>
        <a href="/" class="tr-btn tr-btn--outline">Back to Rooms</a>
    </div>
}
else
{
    <!-- BREADCRUMB -->
    <div class="tr-breadcrumb">
        <a href="/" class="tr-breadcrumb__link">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
            Back to rooms
        </a>
        <span class="tr-breadcrumb__sep">·</span>
        <span class="tr-breadcrumb__current">@_room.Name</span>
    </div>

    <!-- GALLERY -->
    <div class="tr-gallery">
        @if (!string.IsNullOrEmpty(_room.Photo))
        {
            <img src="@_room.Photo" alt="@_room.Name" class="tr-gallery__main" />
        }
        else
        {
            <div class="tr-gallery__placeholder"></div>
        }
        <span class="tr-badge @(_room.IsAvailable ? "tr-badge--gold" : "tr-badge--muted") tr-gallery__badge">
            @(_room.IsAvailable ? "Available" : "Booked")
        </span>
    </div>

    <!-- DETAIL LAYOUT -->
    <div class="tr-detail-layout">

        <!-- INFO -->
        <div class="tr-detail-info">
            <div class="tr-overline">@_room.Location</div>
            <h1 class="tr-detail-title">@_room.Name</h1>

            <div class="tr-detail-meta">
                <div class="tr-detail-meta__item">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
                    </svg>
                    @_room.Location
                </div>
                <div class="tr-detail-meta__item">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                    Up to @_room.Capacity guest@(_room.Capacity != 1 ? "s" : "")
                </div>
            </div>

            <div class="tr-divider" style="margin:20px 0;"><div class="tr-divider__line"></div><div class="tr-divider__diamond"></div><div class="tr-divider__line"></div></div>

            <p class="tr-detail-desc">@_room.Description</p>

            <!-- AMENITIES -->
            <div class="tr-detail-section-title">Amenities</div>
            <div class="tr-amenities">
                <span class="tr-amenity">WiFi</span>
                <span class="tr-amenity">Air Conditioning</span>
                <span class="tr-amenity">Private Bathroom</span>
                <span class="tr-amenity">Daily Cleaning</span>
                @if (_room.Capacity >= 2) { <span class="tr-amenity">King Bed</span> }
                @if (_room.PricePerNight >= 100) { <span class="tr-amenity">Mini Bar</span> <span class="tr-amenity">City View</span> }
            </div>

            <!-- BOOKING INFO MOBILE -->
            <div class="tr-booking-widget tr-booking-widget--mobile">
                <BookingWidget Room="_room" />
            </div>

            <!-- OWNER -->
            @if (_room.User is not null)
            {
                <div class="tr-divider" style="margin:28px 0 20px;"><div class="tr-divider__line"></div><div class="tr-divider__diamond"></div><div class="tr-divider__line"></div></div>
                <div class="tr-detail-section-title">Hosted by</div>
                <div class="tr-host">
                    <div class="tr-host__avatar">
                        @if (!string.IsNullOrEmpty(_room.User.Photo))
                        {
                            <img src="@_room.User.Photo" alt="@_room.User.FullName" />
                        }
                        else
                        {
                            <span>@(_room.User.FullName?[..1] ?? "?")</span>
                        }
                    </div>
                    <div>
                        <div class="tr-host__name">@_room.User.FullName</div>
                        <div class="tr-host__label">Host</div>
                    </div>
                </div>
            }
        </div>

        <!-- BOOKING WIDGET DESKTOP -->
        <div class="tr-booking-widget tr-booking-widget--desktop">
            <BookingWidget Room="_room" />
        </div>

    </div>
}

@code {
    [Parameter] public int RoomId { get; set; }

    private Room? _room = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _room = await _Http.GetFromJsonAsync<Room>($"api/Rooms/{RoomId}");
        }
        catch
        {
            _room = null;
        }
        finally
        {
            _loading = false;
        }
    }
}
