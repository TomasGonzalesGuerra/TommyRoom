@inject NotificationService NotifService
@inject NavigationManager Nav
@using TommyRoom.FrontEnd.Services
@implements IAsyncDisposable

<div class="notif-wrap">
    <button class="notif-bell @(_unread > 0 ? "notif-bell--active" : "")"
            @onclick="ToggleDropdown">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="1.5">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
        </svg>
        @if (_unread > 0)
        {
            <span class="notif-bell__dot">@(_unread > 9 ? "9+" : _unread.ToString())</span>
        }
    </button>

    @if (_open)
    {
        <div class="notif-dropdown">
            <div class="notif-dropdown__header">
                <span>Notifications</span>
                @if (_notifications.Any())
                {
                    <button class="notif-clear" @onclick="ClearAll">Clear all</button>
                }
            </div>

            @if (!_notifications.Any())
            {
                <div class="notif-empty">No notifications yet</div>
            }
            else
            {
                <div class="notif-list">
                    @foreach (var n in _notifications)
                    {
                        <div class="notif-item notif-item--@n.Type.Replace("_", "-") @(n.Read ? "" : "notif-item--unread")">
                            <div class="notif-item__icon">
                                @if (n.Type == "booking_created")
                                {
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                        <rect x="3" y="4" width="18" height="18" rx="2"/>
                                        <line x1="16" y1="2" x2="16" y2="6"/>
                                        <line x1="8" y1="2" x2="8" y2="6"/>
                                        <line x1="3" y1="10" x2="21" y2="10"/>
                                    </svg>
                                }
                                else if (n.Type == "booking_cancelled")
                                {
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                        <circle cx="12" cy="12" r="10"/>
                                        <line x1="15" y1="9" x2="9" y2="15"/>
                                        <line x1="9" y1="9" x2="15" y2="15"/>
                                    </svg>
                                }
                                else
                                {
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                                    </svg>
                                }
                            </div>
                            <div class="notif-item__body">
                                <div class="notif-item__title">@n.Title</div>
                                <div class="notif-item__msg">@n.Message</div>
                                <div class="notif-item__time">@TimeAgo(n.CreatedAt)</div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        @* Borrar después de    q<debuggear *@
        <div style="font-size:9px;color:#666;">
            SignalR: @(NotifService.IsConnected ? "✓ connected" : "✗ disconnected")
            | UserId: @UserId
            | IsAdmin: @IsAdmin
        </div>

        <!-- click fuera cierra el dropdown -->
        <div class="notif-backdrop" @onclick="() => _open = false"></div>
    }
</div>

@code {
    [Parameter] public string?  UserId  { get; set; }
    [Parameter] public bool IsAdmin { get; set; }
    private List<NotifItem> _notifications = new();
    private bool _open;
    private int  _unread => _notifications.Count(n => !n.Read);
    private bool _started;

    protected override async Task OnParametersSetAsync()
    {
        // Solo conectar cuando tengamos el UserId y no hayamos conectado antes
        if (_started) return;
        if (!IsAdmin && string.IsNullOrEmpty(UserId)) return;

        _started = true;
        NotifService.OnNotification += HandleNotification;
        
        var hubUrl = "https://localhost:7227/hubs/notifications";

        await NotifService.StartAsync(hubUrl, UserId, IsAdmin);
    }

    private void HandleNotification(NotificationDTO dto)
    {
        _notifications.Insert(0, new NotifItem
        {
            Type      = dto.Type,
            Title     = dto.Title,
            Message   = dto.Message,
            CreatedAt = dto.CreatedAt,
            Read      = false
        });

        if (_notifications.Count > 20)
            _notifications = _notifications.Take(20).ToList();

        InvokeAsync(StateHasChanged);
    }

    private void ToggleDropdown()
    {
        _open = !_open;
        if (_open)
            foreach (var n in _notifications)
                n.Read = true;
    }

    private void ClearAll()
    {
        _notifications.Clear();
        _open = false;
    }

    private static string TimeAgo(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt;
        if (diff.TotalSeconds < 60)  return "Just now";
        if (diff.TotalMinutes < 60)  return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours   < 24)  return $"{(int)diff.TotalHours}h ago";
        return dt.ToString("MMM dd");
    }

    public async ValueTask DisposeAsync()
    {
        NotifService.OnNotification -= HandleNotification;
    }

    private class NotifItem
    {
        public string   Type      { get; set; } = "";
        public string   Title     { get; set; } = "";
        public string   Message   { get; set; } = "";
        public DateTime CreatedAt { get; set; }
        public bool     Read      { get; set; }
    }
}

