@inject NavigationManager Nav

<aside class="adm-sidebar @(Collapsed ? "adm-sidebar--collapsed" : "")">

    <nav class="adm-sidebar__nav">
        <div class="adm-sidebar__section">
            <div class="adm-sidebar__label">Overview</div>

            <a href="/admin/rooms"
               class="adm-sidebar__item @(IsActive("/admin/rooms") ? "adm-sidebar__item--active" : "")">
                <svg class="adm-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                </svg>
                @if (!Collapsed) { <span>Rooms</span> <span class="adm-sidebar__count">@RoomsCount</span> }
            </a>

            <a href="/admin/bookings"
               class="adm-sidebar__item @(IsActive("/admin/bookings") ? "adm-sidebar__item--active" : "")">
                <svg class="adm-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <rect x="3" y="4" width="18" height="18" rx="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8"  y1="2" x2="8"  y2="6"/>
                    <line x1="3"  y1="10" x2="21" y2="10"/>
                </svg>
                @if (!Collapsed) { <span>Bookings</span> <span class="adm-sidebar__count">@BookingsCount</span> }
            </a>

            <a href="/admin/users"
               class="adm-sidebar__item @(IsActive("/admin/users") ? "adm-sidebar__item--active" : "")">
                <svg class="adm-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                @if (!Collapsed) { <span>Users</span> <span class="adm-sidebar__count">@UsersCount</span> }
            </a>
        </div>

        <div class="adm-sidebar__section adm-sidebar__section--bottom">
            <div class="adm-sidebar__label">@(!Collapsed ? "Account" : "")</div>
            <a href="/profile"
               class="adm-sidebar__item">
                <svg class="adm-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <circle cx="12" cy="8" r="4"/>
                    <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
                </svg>
                @if (!Collapsed) { <span>Profile</span> }
            </a>
            <button class="adm-sidebar__item adm-sidebar__item--danger" @onclick="SignOut">
                <svg class="adm-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
                    <polyline points="16 17 21 12 16 7"/>
                    <line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
                @if (!Collapsed) { <span>Sign Out</span> }
            </button>
        </div>
    </nav>
</aside>

@code {
    [Parameter] public bool Collapsed      { get; set; }
    [Parameter] public int  RoomsCount     { get; set; }
    [Parameter] public int  BookingsCount  { get; set; }
    [Parameter] public int  UsersCount     { get; set; }

    private void SignOut() => Nav.NavigateTo("/login");

    private bool IsActive(string href)
    {
        var current = Nav.ToBaseRelativePath(Nav.Uri);
        return current.StartsWith(href.TrimStart('/'), StringComparison.OrdinalIgnoreCase);
    }
}