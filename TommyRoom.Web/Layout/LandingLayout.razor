@inherits LayoutComponentBase

@Body

<style>
    #app {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    body {
        background-color: var(--backgroundColor);
        overflow: hidden;
    }

    a{cursor: pointer;}

    /* Reset y utilidades */
    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0,0,0,0);
        white-space: nowrap;
        border: 0;
    }

    /* Navbar base */
    .navbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        background: transparent;
        height: var(--navHeight);
        display: flex;
        align-items: center;
        box-shadow: 0 6px 18px rgba(0,0,0,.18);
    }

    .nav-inner {
        max-width: var(--maxWidth);
        margin: 0 auto;
        width: 100%;
        padding: 0 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    /* Brand */
    .brand {
        font-weight: 700;
        font-size: 1.125rem;
        color: inherit;
        text-decoration: none;
    }

    /* Toggle hamburguesa (móvil) */
    .nav-toggle {
        display: flex;
        align-items: center;
        justify-content: center;
        background: transparent;
        border: 0;
        cursor: pointer;
        padding: .5rem;
        margin-left: auto;
    }

    .hamburger {
        display: inline-block;
        width: 28px;
        height: 20px;
        position: relative;
    }

        .hamburger .bar {
            display: block;
            height: 3px;
            background: #111;
            border-radius: 2px;
            margin: 4px 0;
            transition: transform .25s ease, opacity .25s ease;
        }

    /* Cuando el menú está abierto, animar hamburguesa (opcional) */
    .nav-toggle[aria-expanded="true"] .hamburger .bar:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
    }

    .nav-toggle[aria-expanded="true"] .hamburger .bar:nth-child(2) {
        opacity: 0;
    }

    .nav-toggle[aria-expanded="true"] .hamburger .bar:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
    }

    /* Nav links - por defecto ocultos en móvil (panel vertical) */
    .nav-links {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        gap: 1rem;
        align-items: center;
    }
        /* Estilo de links */
        .nav-links a {
            text-decoration: none;
            color: inherit;
            padding: .5rem .75rem;
            border-radius: 6px;
            display: block;
        }

        /* Panel móvil: vertical, overlay */
        .nav-links.open {
            position: fixed;
            top: var(--navHeight);
            left: 0;
            right: 0;
            background: rgba(255,255,255,0.98);
            display: flex;
            flex-direction: column;
            padding: 1rem;
            gap: .5rem;
            box-shadow: 0 8px 30px rgba(0,0,0,.12);
        }

    .nav-links {
        display: flex;
        flex-direction: row;
        position: static;
        background: transparent;
        box-shadow: none;
    }

    .maxW {
        max-width: var(--maxWidth);
    }

    /* Hero y resto (resumen, conserva lo anterior) */
    header {
        background: url('/img/BGTwo.png');
        background-size: cover;
        background-origin: content-box;
        background-position: center;
        background-repeat: no-repeat;
    }

    .hero {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        min-height: 100vh;
    }

    .hero-left {
        flex: 1;
        color: #111;
        z-index: 2;
    }

    /* Search banner */
    .search-banner {
        position: absolute;
        top: 80%;
        left: 20%;
        display: flex;
        justify-content: center;
    }

    .search-inner {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 2rem 3rem;
        border-radius: 1rem;
        background: var(--darkOne);
    }

        .search-inner select, .search-inner input {
            padding: .5rem .75rem;
            border: 1px solid #ddd;
            border-radius: 6px;
            background: #fff;
        }

    .btn-search {
        background: var(--backgroundColor);
        color: #fff;
        padding: .6rem 1rem;
        border-radius: 6px;
        border: none;
        cursor: pointer;
    }


    /* Cuando no abierto en móvil, ocultar completamente (para accesibilidad mantener display:none) */
    @@media (max-width:900px) {
        .nav-links{
            display: none;
        }

        .nav-links.open {
            display: flex;
        }

        .nav-toggle {
            display: block;
        }
    }

    /* A partir de tablet grande (>=901px) mostrar horizontal y ocultar toggle */
    @@media (min-width:901px) {
        .nav-toggle{
            display: none;
        }

        .nav-links {
            display: flex;
            flex-direction: row;
            position: static;
            background: transparent;
            box-shadow: none;
        }
    }

    /* Breakpoints (4) */
    @@media (max-width:600px) { /* móvil */
        .hero {
            flex-direction: column;
            padding-top: 5rem;
        }

        .hero-right {
            height: 180px;
            width: 100%;
        }

        .search-inner {
            flex-direction: column;
            height: auto;
            padding: 1rem;
            gap: .5rem;
        }
    }

    @@media (min-width:601px) and (max-width:900px) { /* tablet pequeńo */
        .search-inner {
            flex-direction: row;
        }
    }

    @@media (min-width:901px) and (max-width:1200px) { /* laptop */
    }

    @@media (min-width:1201px) { /* desktop */
    }

    /* Estilo base del snackbar */
    .snackbar {
        visibility: hidden;
        min-width: 250px;
        background-color: rgba(0, 191, 255, 0.25);
        color: #fff;
        text-align: center;
        border-radius: 1rem;
        border: solid .2rem deepskyblue;
        padding: 2.5rem 5rem;
        position: fixed;
        z-index: 9999;
        left: 10%;
        top: 10%;
        font-size: 16px;
        opacity: 0;
        transition: opacity 0.5s, bottom 0.5s;
    }

        /* Estado visible */
        .snackbar.show {
            visibility: visible;
            opacity: 1;
        }
</style>