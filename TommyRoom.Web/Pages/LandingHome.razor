@page "/landinghome"
@layout LandingLayout

<nav id="mainNav" class="navbar @(navScrolled ? "scrolled" : "")">
    <div class="nav-inner">
        <a class="brand" href="/">MiAlquiler</a>

        <!-- Botón hamburguesa (visible en móvil/tablet pequeño) -->
        <button class="nav-toggle" aria-controls="primaryNav" aria-expanded="@isMenuOpen" @onclick="ToggleMenu" aria-label="Abrir menú">
            <span class="hamburger">
                <span class="bar"></span>
                <span class="bar"></span>
                <span class="bar"></span>
            </span>
        </button>

        <!-- Links principales -->
        <ul id="primaryNav" class="nav-links @(isMenuOpen ? "open" : "")" role="menu">
            <li role="none"><a role="menuitem" href="/">VOLVER</a></li>
            <li role="none"><a role="menuitem" @onclick="ShowThisSnackbar">Habitaciones</a></li>
            <li role="none"><a role="menuitem" @onclick="ShowThisSnackbar">Sobre</a></li>
            <li role="none"><a role="menuitem" @onclick="ShowThisSnackbar">Contacto</a></li>
        </ul>
    </div>
</nav>

<header class="hero">
    <div class="hero-left maxW">
        <h1>Encuentra tu habitación ideal</h1>
        <p>Espacios cómodos, seguros y cerca de todo.</p>
    </div>
</header>

<section class="search-banner">
    <div class="search-inner">
        <label>
            <span class="sr-only">Distrito</span>
            <select aria-label="Distrito">
                <option>Lima Cercado</option>
                <option>Miraflores</option>
                <option>San Isidro</option>
            </select>
        </label>
        <label>
            <span class="sr-only">Fecha inicio</span>
            <input type="date" aria-label="Fecha inicio" />
        </label>
        <label>
            <span class="sr-only">Fecha fin</span>
            <input type="date" aria-label="Fecha fin" />
        </label>
        <button class="btn-search">Buscar</button>
    </div>
</section>

<div class="snackbar @SnackbarClass"><h2>@SnackbarMessage</h2></div>


@code {
    private bool isMenuOpen = false;
    private bool navScrolled = false;
    private string logoSource = "img/logo.png";
    // private string imageSource = "img/person.png";
    private string shapeSource = "img/shape.png";
    private string imageSource = "img/Bg.jpg";
    private bool dark;
    private bool active;
    private bool paint;
    private string SnackbarMessage = "Pronto, Pronto, Pronto ...";
    private string SnackbarClass = string.Empty;


    private void ToggleMenu()
    {
        isMenuOpen = !isMenuOpen;
    }

    private async void Tokaste()
    {
        paint = !paint;
        await Task.Delay(400);
        dark = !dark;
        StateHasChanged();
    }

    private async void ShowThisSnackbar()
    {
        SnackbarClass = "show";
        await Task.Delay(1500);
        SnackbarClass = string.Empty;
        StateHasChanged();
    }
}